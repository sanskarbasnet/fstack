{
  "name": "fstack-brain-cli",
  "version": "0.1.0",
  "private": true,
  "description": "fstack brain CLI — talks to Supabase, called by Claude Code hooks",
  "type": "module",
  "bin": {
    "fstack-brain": "./dist/fstack-brain"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --compile --outfile dist/fstack-brain --target=bun",
    "dev": "bun run ./src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
