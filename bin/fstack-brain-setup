#!/usr/bin/env bash
# fstack-brain-setup — bootstrap the fstack brain layer.
#
# - Builds brain/cli into a single Bun binary
# - Symlinks it to ~/.local/bin/fstack-brain (creates dir if needed)
# - Prompts for config (agent_id, brain_url, brain_anon_key)
# - Writes ~/.fstack/config.yaml
# - Installs Claude Code hooks via hooks/install.ts
# - Runs `fstack-brain doctor`
#
# Idempotent: re-running picks up changes safely.

set -euo pipefail

# Resolve fstack root (this script lives in <root>/bin/)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FSTACK_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI_DIR="$FSTACK_ROOT/brain/cli"
HOOKS_INSTALLER="$FSTACK_ROOT/hooks/install.ts"
FSTACK_HOME="${FSTACK_HOME:-$HOME/.fstack}"
CONFIG_FILE="$FSTACK_HOME/config.yaml"
BIN_TARGET="${FSTACK_BRAIN_BIN:-$HOME/.local/bin/fstack-brain}"

log() { printf "fstack-brain-setup: %s\n" "$*"; }
err() { printf "fstack-brain-setup: ERROR: %s\n" "$*" >&2; }

# 1. Bun check
if ! command -v bun >/dev/null 2>&1; then
  err "bun is not installed. Install Bun first (https://bun.sh) and re-run."
  exit 1
fi

# 2. Build CLI
log "building brain CLI..."
cd "$CLI_DIR"
bun install --silent
mkdir -p dist
bun build ./src/index.ts --compile --outfile dist/fstack-brain --target=bun
cd "$FSTACK_ROOT"

# 3. Install binary on native filesystem (cp, not symlink)
# A symlink to /mnt/<windows-drive>/ on WSL costs ~800ms per invocation
# loading the 88MB binary across the WSL fs boundary. cp to ~/.local/bin
# (native ext4) drops cold-start to ~40ms.
mkdir -p "$(dirname "$BIN_TARGET")"
cp -f "$CLI_DIR/dist/fstack-brain" "$BIN_TARGET"
chmod +x "$BIN_TARGET"
log "installed $BIN_TARGET (copied from $CLI_DIR/dist/fstack-brain)"

# 3b. Also symlink fstack-init onto PATH so users can `fstack-init` from any repo
INIT_SOURCE="$FSTACK_ROOT/bin/fstack-init"
INIT_TARGET="$HOME/.local/bin/fstack-init"
if [ -f "$INIT_SOURCE" ]; then
  ln -sfn "$INIT_SOURCE" "$INIT_TARGET"
  chmod +x "$INIT_SOURCE"
  log "linked $INIT_TARGET → $INIT_SOURCE"
fi

# Verify on PATH
if ! command -v fstack-brain >/dev/null 2>&1; then
  log "WARNING: fstack-brain not on PATH. Add this to your shell rc:"
  log "  export PATH=\"$(dirname "$BIN_TARGET"):\$PATH\""
fi

# 4. Config
mkdir -p "$FSTACK_HOME"
chmod 700 "$FSTACK_HOME"

if [ -f "$CONFIG_FILE" ]; then
  log "config exists at $CONFIG_FILE — keeping (delete to re-prompt)"
else
  log "writing config to $CONFIG_FILE"
  printf "agent_id: "
  read -r AGENT_ID
  printf "brain_url (Supabase URL, e.g. https://xxx.supabase.co): "
  read -r BRAIN_URL
  printf "brain_anon_key (Supabase anon key — paste; input is shown): "
  read -r BRAIN_KEY
  MACHINE="$(hostname 2>/dev/null || echo unknown)"
  cat > "$CONFIG_FILE" <<EOF
agent_id: $AGENT_ID
brain_url: $BRAIN_URL
brain_anon_key: $BRAIN_KEY
machine: $MACHINE
auto_upgrade: false
telemetry: off
EOF
  chmod 600 "$CONFIG_FILE"
  log "config written (mode 600)"
fi

# 5. Install hooks
log "installing Claude Code hooks..."
bun "$HOOKS_INSTALLER"

# 6. Doctor
log "running fstack-brain doctor..."
if ! "$BIN_TARGET" doctor; then
  err "doctor reported failures. Re-check Supabase URL/key and that schema.sql was applied."
  exit 1
fi

# 7. If we were invoked from inside a different git repo, offer to bootstrap it
INVOCATION_CWD="${OLDPWD:-$PWD}"
if [ -d "$INVOCATION_CWD/.git" ] && [ "$INVOCATION_CWD" != "$FSTACK_ROOT" ]; then
  log ""
  log "It looks like you ran setup from inside another git repo:"
  log "  $INVOCATION_CWD"
  log ""
  log "To make Claude Code aware fstack is available there, also run:"
  log "  cd $INVOCATION_CWD && fstack-init"
  log ""
fi

log "✓ setup complete."
log "  - Open Claude Code in any repo and try '/fstack-help' or '/sync'."
log "  - In each project repo where you want fstack visible to Claude Code,"
log "    cd into it and run: fstack-init"
