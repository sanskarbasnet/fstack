#!/usr/bin/env bash
# fstack-review-read — read review log and config for dashboard
# Usage: fstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/fstack-slug" 2>/dev/null)"
FSTACK_HOME="${FSTACK_HOME:-$HOME/.fstack}"
cat "$FSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/fstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
